  "license": "MIT",
  "private": false,
  "author": {
    "name": "Madan Sapkota",
    "role": "Maintainer",
    "email": "contact+github@madansapkota.com",
    "url": "https://madansapkota.com"
  },
  "keywords": [
    "ad-to-bs",
    "bikram-sambat",
    "bs-to-ad",
    "date-conversion",
    "miti-pariwartan",
    "nepali-calendar",
    "nepali-date",
    "nepali-date-converter",
    "nepali-date-formatter",
    "nepali-date-library",
    "nepali-date-tool",
    "nepali-date-utility",
    "nepali-miti"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remotemerge/nepali-date-converter.git"
  },
  "bugs": {
    "url": "https://github.com/remotemerge/nepali-date-converter/issues"
  },
  "engines": {
    "bun": ">=1.3.11 <2.0.0"
  },
  "prettier": {
    "singleQuote": true
  },
  "type": "module",
  "scripts": {
    "lint": "eslint **/*.ts",
    "lint:fix": "eslint **/*.ts --fix",
    "test": "bun test",
    "dev": "vite --host 0.0.0.0 --port 3000",
    "preview": "vite preview",
    "build": "vite build && bun ./maker/package-manager.ts"
  },
  "dependencies": {
    "date-fns": "^4.1.0"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "bun-types": "^1.3.11",
    "eslint": "^10.2.0",
    "eslint-plugin-prettier": "^5.5.5",
